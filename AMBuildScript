import os

def PrependPathIfExists(path):
  if path and os.path.isdir(path):
    os.environ['PATH'] = path + os.pathsep + os.environ.get('PATH', '')

PrependPathIfExists(os.environ.get('SBT_MSVC_BIN'))
PrependPathIfExists(os.environ.get('SBT_WINSDK_BIN'))
PrependPathIfExists(r'C:\Program Files\Microsoft Visual Studio\2022\Community\VC\Tools\MSVC\14.44.35207\bin\Hostx64\x64')
PrependPathIfExists(r'C:\Program Files (x86)\Windows Kits\10\bin\10.0.26100.0\x64')

def ResolveEnvPath(env, folder):
  if env in os.environ:
    path = os.environ[env]
    if os.path.isdir(path):
      return path

  head = os.getcwd()
  oldhead = None
  while head is not None and head != oldhead:
    path = os.path.join(head, folder)
    if os.path.isdir(path):
      return path
    oldhead = head
    head, tail = os.path.split(head)

  return None

def ResolveMMSRoot():
  if builder.options.mms_path and os.path.isdir(builder.options.mms_path):
    return os.path.abspath(os.path.normpath(builder.options.mms_path))

  for env, folder in [
    ('MMSOURCE20', 'mmsource-2.0'),
    ('MMSOURCE112', 'mmsource-1.12'),
    ('MMSOURCE_DEV', 'metamod-source'),
  ]:
    path = ResolveEnvPath(env, folder)
    if path:
      return os.path.abspath(os.path.normpath(path))

  raise Exception('Could not find a source copy of Metamod:Source')

mms_root = ResolveMMSRoot()

if not builder.options.hl2sdk_manifests:
  raise Exception('Could not find a source copy of HL2SDK manifests')

SdkHelpers = builder.Eval(os.path.join(builder.options.hl2sdk_manifests, 'SdkHelpers.ambuild'), {
  'Project': 'metamod'
})

class MMSPluginConfig(object):
  def __init__(self):
    self.sdk_manifests = []
    self.sdks = {}
    self.sdk_targets = []
    self.binaries = []
    self.mms_root = mms_root
    self.all_targets = []

    self.plugin_name = builder.options.plugin_name or 'swiftlybhoptimer_helper'
    self.plugin_alias = builder.options.plugin_alias or 'swiftlybhoptimer_helper'

    target_archs = builder.options.targets.split(',') if builder.options.targets else ['x86_64']
    for arch in target_archs:
      cxx = builder.DetectCxx(target_arch=arch)
      self.all_targets.append(cxx)

    if not self.all_targets:
      raise Exception('No suitable C/C++ compiler was found.')

  def findSdkPath(self, sdk_name):
    dir_name = 'hl2sdk-{}'.format(sdk_name)
    if builder.options.hl2sdk_root:
      sdk_path = os.path.join(builder.options.hl2sdk_root, dir_name)
      if os.path.exists(sdk_path):
        return sdk_path
    return ResolveEnvPath('HL2SDK{}'.format(sdk_name.upper()), dir_name)

  def detectSDKs(self):
    sdk_list = [s for s in builder.options.sdks.split(',') if s]
    SdkHelpers.find_sdk_path = self.findSdkPath
    SdkHelpers.findSdks(builder, self.all_targets, sdk_list)

    self.sdks = SdkHelpers.sdks
    self.sdk_manifests = SdkHelpers.sdk_manifests
    self.sdk_targets = SdkHelpers.sdk_targets

    if len(self.sdks) > 1:
      raise Exception('Only one SDK at a time is supported.')

  def configure(self):
    for cxx in self.all_targets:
      self.configure_cxx(cxx)

  def configure_cxx(self, cxx):
    if cxx.behavior == 'gcc':
      cxx.defines += [
        'stricmp=strcasecmp',
        '_stricmp=strcasecmp',
        '_snprintf=snprintf',
        '_vsnprintf=vsnprintf',
        'HAVE_STDINT_H',
        'GNUC',
      ]
      cxx.cflags += [
        '-pipe',
        '-fno-strict-aliasing',
        '-Wall',
        '-Wno-uninitialized',
        '-Wno-unused',
        '-Wno-switch',
        '-msse',
        '-fPIC',
      ]
      cxx.cxxflags += [
        '-std=c++17',
        '-fno-exceptions',
        '-fno-threadsafe-statics',
        '-Wno-non-virtual-dtor',
        '-Wno-overloaded-virtual',
      ]
      cxx.cflags += ['-fno-omit-frame-pointer']
      if cxx.family == 'gcc':
        cxx.cflags += ['-mfpmath=sse']
      if cxx.target.platform == 'linux':
        cxx.defines += ['LINUX', '_LINUX', 'POSIX', '_FILE_OFFSET_BITS=64']
        cxx.linkflags += ['-static-libgcc', '-static-libstdc++']

    elif cxx.like('msvc'):
      cxx.cflags += ['/MT', '/W3', '/Zi', '/std:c++17']
      cxx.cxxflags += ['/TP']
      cxx.defines += [
        '_CRT_SECURE_NO_DEPRECATE',
        '_CRT_SECURE_NO_WARNINGS',
        '_CRT_NONSTDC_NO_DEPRECATE',
        'WIN32',
        '_WINDOWS',
      ]
      cxx.linkflags += [
        '/SUBSYSTEM:WINDOWS',
        'kernel32.lib',
        'user32.lib',
        'advapi32.lib',
      ]

    if builder.options.opt == '1':
      cxx.defines += ['NDEBUG']
      if cxx.behavior == 'gcc':
        cxx.cflags += ['-O3']
      elif cxx.like('msvc'):
        cxx.cflags += ['/Ox', '/Zo']
        cxx.linkflags += ['/OPT:ICF', '/OPT:REF']

    if builder.options.debug == '1':
      cxx.defines += ['DEBUG', '_DEBUG']
      if cxx.behavior == 'gcc':
        cxx.cflags += ['-g3']
      elif cxx.like('msvc'):
        cxx.cflags += ['/Od', '/RTC1']

  def Library(self, cxx, name):
    return cxx.Library(name)

  def HL2Library(self, context, compiler, name, sdk):
    binary = self.Library(compiler, name)
    cxx = binary.compiler

    mms_core_path = os.path.join(self.mms_root, 'core')
    cxx.cxxincludes += [
      os.path.join(context.currentSourcePath),
      os.path.join(mms_core_path),
      os.path.join(mms_core_path, 'sourcehook'),
    ]

    for other_sdk in self.sdk_manifests:
      cxx.defines += ['SE_{}={}'.format(other_sdk['define'], other_sdk['code'])]

    if sdk['source2']:
      cxx.defines += ['META_IS_SOURCE2']
      binary.sources += [
        os.path.join(sdk['path'], 'public', 'tier0', 'memoverride.cpp'),
        os.path.join(sdk['path'], 'tier1', 'convar.cpp'),
      ]

    SdkHelpers.configureCxx(context, binary, sdk)
    return binary

MMSPlugin = MMSPluginConfig()
MMSPlugin.detectSDKs()
MMSPlugin.configure()

builder.Build(['AMBuilder', 'PackageScript'], { 'MMSPlugin': MMSPlugin })
